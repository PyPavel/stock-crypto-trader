# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.

# Coinbase Advanced Trade API credentials
COINBASE_API_KEY=organizations/<org-id>/apiKeys/<key-id>
# PEM key on one line with literal \n between each line of the key:
COINBASE_API_SECRET=-----BEGIN EC PRIVATE KEY-----\nMHcCAQEE...\n-----END EC PRIVATE KEY-----

# Xiaomi Mimo API key — used by the sentiment analyser (get yours at platform.xiaomimimo.com)
MIMO_API_KEY=your_mimo_api_key

# Optional: Reddit API credentials (leave blank to disable Reddit collector)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Alpaca API credentials — used by the stocks trader service
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret

# Telegram notifications — get a bot token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789
